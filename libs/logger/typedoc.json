{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "src/index.ts"
  ],
  "out": "../../docs/system/Logger",
  "plugin": [
    "typedoc-plugin-markdown"
  ],
  "theme": "markdown", // Use the Markdown theme
  "readme": "none", // No default README.md
  "includeVersion": true, // Show your package version
  "hideGenerator": false, // Show “Generated by TypeDoc”
  "exclude": [
    "**/__tests__/**",
    "**/*.spec.ts",
    "**/node_modules/**"
  ],
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeExternals": true,
  "markdown": {
    "toc": true, // Generate a TOC
    "frontmatter": {
      "title": "@helix/logger",
      "sidebar_label": "Logger"
    }
  },
  "gitRemote": "origin", // For “Edit on GitHub” links if desired
  "hideBreadcrumbs": true // Cleaner Markdown
}