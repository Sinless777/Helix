{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/@helix/logger",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "jest.config.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "**/*.mock.ts"
  ]
}