// libs/logger/tsconfig.spec.json
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/libs/logger/spec",
    "types": [
      "jest",
      "node"
    ],
    "esModuleInterop": true,
    "allowJs": true,
    "sourceMap": true,
    "noImplicitAny": false
  },
  "include": [
