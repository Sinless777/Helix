# ===================================================
# 📦 Package Managers & Build Artifacts
# ===================================================
**/**/node_modules/
**/**/dist/
**/**/build/
**/**/.next/
**/**/.turbo/
**/**/.output/
**/**/.vercel/
**/**/.yarn/*
**/**/.pnp
**/**/.pnp.*
**/**/.tsbuildinfo

# Allow specific Yarn folders
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

.husky/ # Husky hooks
# ===================================================
# ⚙️ Configuration, Secrets, and Environment Files
# ===================================================
**/**/.env
**/**/.env.*
**/**/.env.local

# ===================================================
# 🧪 Testing, Coverage & Snapshots
# ===================================================
**/**/coverage/
**/**/__snapshots__/
**/**/.nyc_output/
**/**/report.[0-9]*.json

# ===================================================
# 🐞 Logs & Runtime Data
# ===================================================
**/*.log
**/*.pid
**/*.seed
**/*.pid.lock
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ===================================================
# 🛠 IDEs & Editor Configs
# ===================================================
**/.idea/
**/.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
**/.sublime-workspace
**/.history
**/.project
**/.classpath
**/.settings/
**/.c9/

# ===================================================
# 🗂 Miscellaneous OS/System/Temporary Files
# ===================================================
.DS_Store
*.pem
*.swp
*.swo
.temp/
.tmp/
.vscode/*
.next-tasks/
