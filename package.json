{
  "name": "@helix/source",
  "version": "1.0.0",
  "packageManager": "pnpm@10.11.1+sha512.e519b9f7639869dc8d5c3c5dfef73b3f091094b0a006d7317353c72b124e80e1afd429732e28705ad6bfa1ee879c1fce46c128ccebd3192101f43dd67c667912",
  "scripts": {
    "build:frontend": "pnpm --filter @helix/frontend build",
    "build:auth": "pnpm --filter @helix/auth build",
    "build:core": "pnpm --filter @helix/core build",
    "build:logger": "pnpm --filter @helix/logger build",
    "build:database": "pnpm --filter @helix/database build",
    "build:all": "pnpm run build:core && pnpm run build:logger && pnpm run build:database && pnpm run build:auth && pnpm run build:frontend",
    "lint:frontend": "pnpm --filter @helix/frontend lint",
    "lint:auth": "pnpm --filter @helix/auth lint",
    "lint:core": "pnpm --filter @helix/core lint",
    "lint:logger": "pnpm --filter @helix/logger lint",
    "lint:database": "pnpm --filter @helix/database lint",
    "lint:all": "pnpm run lint:core && pnpm run lint:logger && pnpm run lint:database && pnpm run lint:auth && pnpm run lint:frontend",
    "test:frontend": "pnpm --filter @helix/frontend test",
    "test:auth": "pnpm --filter @helix/auth test",
    "test:core": "pnpm --filter @helix/core test",
    "test:logger": "pnpm --filter @helix/logger test",
    "test:database": "pnpm --filter @helix/database test",
    "test:all": "pnpm run test:core && pnpm run test:logger && pnpm run test:database && pnpm run test:auth && pnpm run test:frontend",
    "test:ci": "pnpm run test:all",
    "test:coverage": "pnpm run test:all -- --coverage",
    "test:coverage:report": "pnpm run test:all -- --coverage --coverageReporters=html",
    "test:coverage:check": "pnpm run test:all -- --coverage --coverageReporters=text-lcov | coveralls",
    "test:watch": "pnpm run test:all -- --watch",
    "format:frontend": "pnpm --filter @helix/frontend format"
  },
  "dependencies": {
    "next": "^15.3.2"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --max-warnings=0 --fix --",
      "prettier --write --"
    ],
    "**/*.{html,json,css,scss,md,mdx}": [
      "prettier --write --"
    ]
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.797.0",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@commitlint/config-nx-scopes": "19.8.1",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.25.1",
    "@module-federation/enhanced": "^0.15.0",
    "@module-federation/runtime-tools": "^0.15.0",
    "@rollup/plugin-url": "^8.0.2",
    "@rspack/core": "^1.3.7",
    "@svgr/core": "^8.1.0",
    "@svgr/rollup": "^8.1.0",
    "@swc-node/register": "^1.10.10",
    "@swc/core": "^1.3.0",
    "@swc/jest": "^0.2.38",
    "@testing-library/react": "^16.3.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "axios": "^1.9.0",
    "browserslist": "^4.24.4",
    "cypress": "^14.3.2",
    "dmg-builder": "^25.1.8",
    "encoding": "^0.1.13",
    "eslint": "9.28.0",
    "eslint-config-next": "^15.3.1",
    "eslint-plugin-cypress": "^4.3.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-resolve": "^29.7.0",
    "less": "^4.1.3",
    "lint-staged": "^15.5.1",
    "picomatch": "4.0.2",
    "pnpm": "^10.9.0",
    "postcss": "^8.5.3",
    "prettier": "3.5.3",
    "sass": "^1.87.0",
    "sass-embedded": "^1.87.0",
    "stylus": "^0.64.0",
    "ts-jest": "^29.3.3",
    "ts-lib": "^0.0.5",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.4",
    "typedoc-plugin-rename-defaults": "^0.7.3",
    "typedoc-theme-hierarchy": "^6.0.0",
    "typescript": "5.8.3",
    "unenv": "2.0.0-rc.17",
    "webpack": "^5.99.7",
    "ws": "^8.18.0"
  }
}
