{
  "[markdown]": {
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.markdownlint": true
  },
  "markdownlint.config": {
    "default": true,
    "MD013": false,
    "MD024": false,
    "MD025": false,
    "MD029": false,
    "MD036": false,
    "MD041": false
  },
  "markdownlint.trace.server": "off"
}
