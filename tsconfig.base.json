{
  "compileOnSave": false,
  "compilerOptions": {
    "checkJs": false,
    "target": "ES2020",
    "module": "ESNext",
    "noImplicitAny": false,
    "lib": [
      "ESNext",
      "DOM"
    ],
    "moduleResolution": "node",
    "baseUrl": ".",
    "rootDir": ".",
    "paths": {
      "@helix/core/*": [
        "libs/core/src/*"
      ],
      "@helix/database/*": [
        "libs/database/src/*"
      ],
      "@helix/logger/*": [
        "libs/logger/src/*"
      ],
      "@helix/ui/*": [
        "libs/ui/src/*"
      ],
      "@helix/auth/*": [
        "apis/auth/src/*"
      ],
      "@helix/frontend/*": [
        "user-interfaces/frontend/src/*"
      ]
    },
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "incremental": true,
    "composite": true,
    "strict": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false
  },
  "exclude": [
    "node_modules",
    "dist",
    "tmp",
    "**/*.spec.ts",
    "**/*.test.ts"
  ],
  "include": [
    "./jest.config.base.ts"
  ]
}