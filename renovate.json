{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "repositoryType": "monorepo",
  "packageDirectories": [
    { "packageDir": ".", "groupName": "root packages" },
    { "packageDir": "apis/*", "groupName": "APIs" },
    { "packageDir": "libs/*", "groupName": "Libraries" },
    { "packageDir": "user-interfaces/*", "groupName": "UI" },
    {
      "packageDir": "docker",
      "packageFile": "docker/Data-Layer.yaml",
      "groupName": "Docker images"
    }
  ],
  "docker": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchPackagePatterns": ["*"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest"],
      "milestone": "🔗 Dependency Management"
    }
  ]
}
