# Packages           #
# -------------------#
brew "git"                  # Git version control
brew "wget"                 # Wget for downloading files
brew "curl"                 # Curl for transferring data with URLs
brew "tree"                 # Tree command for displaying directory structure
brew "pipx"                 # Pipx for managing Python applications
brew "go-task"              # Go Task for task management
